---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'MCM Amateur Radio Operations — amateur radio communications support for the Marine Corps Marathon.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

/** Bumps when favicon assets change — avoids stale browser cache */
const faviconV = '3';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${faviconV}`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`/favicon-32x32.png?v=${faviconV}`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`/favicon-16x16.png?v=${faviconV}`} />
    <link rel="icon" href={`/favicon.ico?v=${faviconV}`} sizes="any" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900 antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
