---
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white mt-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-bold text-lg mb-3">MCM Amateur Radio Operations</h3>
        <p class="text-gray-400 text-sm">
          Supporting the Marine Corps Marathon with professional amateur radio communications for 48
          years.
        </p>
      </div>
      <div>
        <h3 class="font-bold text-lg mb-3">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/volunteer" class="text-gray-400 hover:text-white transition">Volunteer</a>
          </li>
          <li>
            <a href="/faq" class="text-gray-400 hover:text-white transition">FAQ</a>
          </li>
          <li>
            <a
              href="https://www.marinemarathon.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-400 hover:text-white transition">Marine Corps Marathon</a
            >
          </li>
        </ul>
      </div>
      <div>
        <h3 class="font-bold text-lg mb-3">Contact</h3>
        <p class="text-gray-400 text-sm">
          Questions? Visit our <a href="/contact" class="underline hover:text-white transition"
            >Contact page</a
          >
        </p>
      </div>
    </div>
    <div class="border-t border-gray-800 mt-8 pt-6 text-center text-sm text-gray-400">
      <p>&copy; {year} MCM Amateur Radio Operations. All rights reserved.</p>
    </div>
  </div>
</footer>
