---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout title="Page Not Found | MCM Amateur Radio Operations" description="The requested page could not be found.">
  <div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
    <div class="text-center max-w-2xl">
      <Icon name="lucide:radio" class="w-24 h-24 mx-auto text-gray-400 mb-6 opacity-50" aria-hidden="true" />
      <h1 class="text-6xl font-bold text-gray-900 mb-4">404</h1>
      <h2 class="text-3xl font-bold text-gray-800 mb-4">Page Not Found</h2>
      <p class="text-lg text-gray-600 mb-8">
        Looks like this frequency isn't broadcasting. The page you're looking for doesn't exist or has been
        moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-[#CC0000] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[#A00000] transition"
        >
          <Icon name="lucide:home" class="w-5 h-5" aria-hidden="true" />
          Back to Home
        </a>
        <a
          href="/volunteer"
          class="inline-flex items-center justify-center gap-2 bg-white text-[#CC0000] border-2 border-[#CC0000] px-6 py-3 rounded-lg font-semibold hover:bg-gray-50 transition"
        >
          <Icon name="lucide:search" class="w-5 h-5" aria-hidden="true" />
          Volunteer Registration
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
