---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { faqs } from '../data/faqs';
---

<BaseLayout
  title="FAQ | MCM Amateur Radio Operations"
  description="Frequently asked questions about volunteering as an amateur radio operator for the Marine Corps Marathon."
>
  <div class="py-12 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <Icon name="lucide:circle-help" class="w-16 h-16 mx-auto text-[#CC0000] mb-4" aria-hidden="true" />
        <h1 class="text-4xl font-bold mb-4">Frequently Asked Questions</h1>
        <p class="text-lg text-gray-700">
          Common questions about volunteering as an amateur radio operator for the Marine Corps Marathon
        </p>
      </div>

      <div class="space-y-4 mb-12">
        {
          faqs.map((faq) => (
            <details class="border border-gray-200 rounded-lg overflow-hidden group">
              <summary class="w-full px-6 py-4 flex justify-between items-center bg-white hover:bg-gray-50 transition text-left cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <span class="font-semibold text-gray-900 pr-4">{faq.question}</span>
                <Icon
                  name="lucide:chevron-down"
                  class="w-5 h-5 text-gray-500 shrink-0 transition-transform group-open:rotate-180"
                  aria-hidden="true"
                />
              </summary>
              <div class="px-6 py-4 bg-gray-50 border-t border-gray-200">
                <div
                  class="text-gray-700 whitespace-pre-line [&_a]:font-semibold [&_a]:text-[#CC0000] [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-[#A00000]"
                  set:html={faq.answer}
                />
              </div>
            </details>
          ))
        }
      </div>

      <div class="bg-white rounded-lg shadow-sm p-8 text-center border border-gray-200">
        <h2 class="text-2xl font-bold mb-4">Still Have Questions?</h2>
        <p class="text-gray-700 mb-6">
          If you didn't find the answer you were looking for, please don't hesitate to reach out to our team.
        </p>
        <a
          href="/contact"
          class="inline-block bg-[#CC0000] text-white px-8 py-3 rounded-lg font-bold hover:bg-[#A00000] transition"
        >
          Contact Us
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
