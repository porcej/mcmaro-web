---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { updates, type UpdateType } from '../data/updates';

function updateIcon(type: UpdateType) {
  switch (type) {
    case 'alert':
      return 'lucide:circle-alert';
    case 'success':
      return 'lucide:circle-check';
    default:
      return 'lucide:info';
  }
}

function updateIconClass(type: UpdateType) {
  switch (type) {
    case 'alert':
      return 'w-6 h-6 text-orange-600';
    case 'success':
      return 'w-6 h-6 text-green-600';
    default:
      return 'w-6 h-6 text-blue-600';
  }
}

function updateBorder(type: UpdateType) {
  switch (type) {
    case 'alert':
      return 'border-orange-500';
    case 'success':
      return 'border-green-500';
    default:
      return 'border-blue-500';
  }
}

function updateBg(type: UpdateType) {
  switch (type) {
    case 'alert':
      return 'bg-orange-50';
    case 'success':
      return 'bg-green-50';
    default:
      return 'bg-blue-50';
  }
}
---

<BaseLayout
  title="Updates | MCM Amateur Radio Operations"
  description="News and announcements for MCM Amateur Radio Operations volunteers."
>
  <div class="py-12 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <Icon name="lucide:bell" class="w-16 h-16 mx-auto text-[#CC0000] mb-4" aria-hidden="true" />
        <h1 class="text-4xl font-bold mb-4">Updates & Announcements</h1>
        <p class="text-lg text-gray-700">
          Stay informed about the latest news, dates, and information for MCM Amateur Radio Operations
        </p>
      </div>

      <div class="bg-white rounded-lg shadow-sm p-6 mb-8 border border-gray-200">
        <h2 class="text-xl font-bold mb-3">Get Email Updates</h2>
        <p class="text-gray-700 mb-4">
          Register as a volunteer to receive email notifications about important dates, frequency assignments,
          and race day information.
        </p>
        <a
          href="/volunteer"
          class="inline-block bg-[#CC0000] text-white px-6 py-2 rounded-md font-semibold hover:bg-[#A00000] transition"
        >
          Register to Volunteer
        </a>
      </div>

      <div class="space-y-6">
        {
          updates.map((update) => (
            <div
              class={`${updateBg(update.type)} border-l-4 ${updateBorder(update.type)} rounded-r-lg p-6 shadow-sm`}
            >
              <div class="flex gap-4">
                <div class="shrink-0 mt-1">
                  <Icon name={updateIcon(update.type)} class={updateIconClass(update.type)} aria-hidden="true" />
                </div>
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-2">
                    <Icon name="lucide:calendar" class="w-4 h-4 text-gray-600" aria-hidden="true" />
                    <span class="text-sm font-semibold text-gray-600">{update.date}</span>
                  </div>
                  <h3 class="text-xl font-bold mb-3 text-gray-900">{update.title}</h3>
                  <p class="text-gray-700 leading-relaxed">{update.content}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-12 bg-white rounded-lg shadow-sm p-6 border border-gray-200 text-center">
        <h3 class="font-bold text-lg mb-2">Looking for Older Updates?</h3>
        <p class="text-gray-700">
          Updates are archived after one year. For historical information or past event details, please{' '}
          <a href="/contact" class="text-[#CC0000] hover:underline font-semibold">contact us</a>.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
